# Serveur
PORT=5000
NODE_ENV=development

# Base de données (Railway génère DATABASE_URL automatiquement en production)
DATABASE_URL=postgresql://user:password@localhost:5432/renteasy

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:3000,https://renteasy-frontend.vercel.app,https://renteasy.bj

# Mobile Money - MTN MoMo
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_TARGET_ENV=sandbox
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Mobile Money - Moov Money
MOOV_API_KEY=
MOOV_API_SECRET=
MOOV_BASE_URL=

# Email (Brevo - comme OJADA BANK)
BREVO_API_KEY=
EMAIL_FROM=noreply@renteasy.bj
